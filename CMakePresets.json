{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-vs2022",
      "displayName": "Windows Visual Studio 2022",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2022",
      "cacheVariables": {
        "HIPCV_ENABLE_HIP": "ON",
        "HIPCV_BUILD_EXAMPLES": "ON",
        "HIPCV_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-vs2022-no-hip",
      "displayName": "Windows Visual Studio 2022 without HIP",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2022-no-hip",
      "cacheVariables": {
        "HIPCV_ENABLE_HIP": "OFF",
        "HIPCV_BUILD_EXAMPLES": "ON",
        "HIPCV_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-vs2026",
      "displayName": "Windows Visual Studio 2026",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2026",
      "cacheVariables": {
        "HIPCV_ENABLE_HIP": "ON",
        "HIPCV_BUILD_EXAMPLES": "ON",
        "HIPCV_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-vs2026-no-hip",
      "displayName": "Windows Visual Studio 2026 without HIP",
      "generator": "Visual Studio 18 2026",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-vs2026-no-hip",
      "cacheVariables": {
        "HIPCV_ENABLE_HIP": "OFF",
        "HIPCV_BUILD_EXAMPLES": "ON",
        "HIPCV_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "windows-ci-no-hip",
      "displayName": "Windows CI without HIP",
      "generator": "NMake Makefiles",
      "binaryDir": "${sourceDir}/build/windows-ci-no-hip",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "HIPCV_ENABLE_HIP": "OFF",
        "HIPCV_BUILD_EXAMPLES": "ON",
        "HIPCV_BUILD_TESTS": "ON",
        "HIPCV_BUILD_BENCHMARKS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-vs2022-release",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2022-no-hip-release",
      "configurePreset": "windows-vs2022-no-hip",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2026-release",
      "configurePreset": "windows-vs2026",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2026-no-hip-release",
      "configurePreset": "windows-vs2026-no-hip",
      "configuration": "Release"
    },
    {
      "name": "windows-ci-no-hip",
      "configurePreset": "windows-ci-no-hip"
    }
  ],
  "testPresets": [
    {
      "name": "windows-vs2022-release",
      "configurePreset": "windows-vs2022",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2022-no-hip-release",
      "configurePreset": "windows-vs2022-no-hip",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2026-release",
      "configurePreset": "windows-vs2026",
      "configuration": "Release"
    },
    {
      "name": "windows-vs2026-no-hip-release",
      "configurePreset": "windows-vs2026-no-hip",
      "configuration": "Release"
    },
    {
      "name": "windows-ci-no-hip",
      "configurePreset": "windows-ci-no-hip"
    }
  ]
}
